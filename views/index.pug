- var loop = 0;
- var html = false;
//|<?xml version="1.0" encoding="UTF-8" ?>
html(b:css='false' b:version='2' class='v2' b:layoutsVersion='3' b:js='false' expr:lang="data:blog.locale" expr:dir='data:blog.languageDirection' b:responsive="true"  b:templateVersion='1.3.0' mlns='http://www.w3.org/1999/xhtml' xmlns:b='http://www.google.com/2005/gml/b' xmlns:data='http://www.google.com/2005/gml/data' xmlns:expr='http://www.google.com/2005/gml/expr')
    <head>
        //script
            include partials/js/loading.js
        | <b:include data='blog' name='all-head-content'/>
        meta(charset='UTF-8')
        //data:description
        meta(name="description" content="Neetoons es un freelancer que ha trabajado en diferentes campos de la tecnologia quien te cuenta sus experiencias")
        meta(name="keywords" content="tecnologia, creatividad, emprendimiento")
        if html
            meta(name='viewport' content='width=device-width, initial-scale=1')
        else
            | <meta expr:content='data:blog.isMobile ? "width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=1" : "width=device-width,initial-scale=1"' name='viewport'/> 
        title
            b:if(cond="data:view.isHomepage")
                |<data:blog.title/>                
            b:if(cond="data:view.isHomepage != true")
                |<data:view.title/> - <data:blog.title/>                

        // bootstrap
        link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/normalize/8.0.1/normalize.min.css")
        link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css")
        link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-eOJMYsd53ii+scO/bJGFsiCZc+5NDVN2yr8+0RDqr0Ql0h+rP48ckxlpbzKgwra6" crossorigin="anonymous")
        // code hightlights with https://highlightjs.org/
        link(href='https://cdnjs.cloudflare.com/ajax/libs/highlight.js/9.15.6/styles/atom-one-dark-reasonable.min.css' rel='stylesheet') 
        link(href='https://fonts.googleapis.com/css?family=Archivo+Black' rel='stylesheet') 


        if html
            style
                include partials/css/styles.css
                include partials/css/header-games.css
        else
            b:skin 
                | <![CDATA[
                include partials/css/styles.css
                include partials/css/header-games.css
                | ]]>
    |&lt;!--
    </head>
    //Body
    body.bg-negro
        include partials/header.pug
        include partials/body.pug
        //bootstrap js
        script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta3/dist/js/bootstrap.min.js" integrity="sha384-j0CNLUeiqtyaRmlzUHCPZ+Gy5fQu0dQ6eZ/xAww941Ai1SxSY+0EQqNXNE6DZiVc" crossorigin="anonymous")
        script(type="text/javascript")
            include partials/js/scripts.js
        b:if(cond="data:view.isHomepage")
            script(type="text/javascript")
                include partials/js/recientes.js  
        b:if(cond="data:view.isPost")
            script(src='//cdnjs.cloudflare.com/ajax/libs/highlight.js/9.15.6/highlight.min.js')
            script(src='//cdnjs.cloudflare.com/ajax/libs/highlight.js/9.15.6/languages/r.min.js')
            script(type="text/javascript")
                include partials/js/post.js
        footer
        include partials/footer.pug
