{
  "name": "Neetoons-blog",
  "version": "1.0.0-alpha",
  "description": "A blogger theme made with bootstrap and pugjs",
  "main": "",
  "dependencies": {
    "live-server": "^1.2.2",
    "pug-cli": "^1.0.0-alpha6"
  },
  "scripts": {
    "build": "pug --out ./dest --extension xml --pretty --watch ./views/index.pug",
    "html": "pug --out ./dest  --extension html --pretty --watch ./views/index.pug",
    "dev": "live-server ./dest"
  },
  "keywords": [
    "Blogger",
    "theme",
    "blog",
    "xml",
    "pugjs"
  ],
  "author": "Neetoons",
  "license": "ISC"
}
